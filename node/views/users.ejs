<%- include("header.ejs", {style: "users"}) %>

<div class="overlay"></div>

<div class="add-users-modal">
    <i class="fa-regular fa-circle-xmark close-forms"></i>
    <form action="" method="post">
        <h5 class="add-users-heading">Add Members (comma separated emails)</h5>
        <textarea id="addMembers" class="form-control add-users-text-box" placeholder="example1@gmail.com, example2@gmail.com, ..."></textarea>
        <button type="submit" class="btn btn-primary">Invite</button>
    </form>
</div>

<div class="role-editor">
    <i class="fa-regular fa-circle-xmark close-forms"></i>
    <h4 class="role-editor-heading"></h4>
    <ul class="list-group roles-container">
        <% ["admin", "approvalCreator", "approvalEditor", "removeUser", "addUser"].forEach(role => { %>
            <li class="list-group-item">
                <input class="form-check-input me-1" type="checkbox" value="" id="<%= role %>">
                <label class="form-check-label" for="<%= role %>"><%= role %></label>
            </li>
            <% }); %>
        </ul>
    <button type="button" class="btn btn-primary save-button">Save</button>
</div>

<ul class="list-group container">
    <li class="list-group-item add-user-button"><i class="fa-solid fa-plus plus-icon"></i></li>
    <% for (let i = 0; i < users.length; i++) { %>
        <li class="list-group-item items" data-user-data="<%= JSON.stringify(users[i]) %>">
            <p class="user-name"><%= users[i].userName %></p>
            <div class="btn-group" role="group" aria-label="Basic example">
                <button type="button" class="btn btn-success details">Details</button>
                <button type="button" class="btn btn-warning edit-role">Edit Role</button>
                <button type="button" class="btn btn-danger remove">Remove</button>
            </div>
        </li>
    <% } %>
</ul>

<%- include("footer.ejs", {script: "users"}) %>