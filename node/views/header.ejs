<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Approval Rounds</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Aldrich&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="header.css">
    <link rel="stylesheet" href="<%= style %>.css">
</head>
<body>

<% if (style !== 'index') {%>
    <nav class="navbar navbar-expand-md edit-navbar" data-bs-theme="dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="#">Navbar</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav me-auto mb-2 mb-md-0 custom-links-gap">
            <li class="nav-item">
            <a class="nav-link workspaces-link" href="/">Workspaces</a>
            </li>
            <li class="nav-item">
                <a class="nav-link pending-approval-link" href="/workspace/<%= workspaceId %>/pending-approvals">Pending Approvals</a>
            </li>
            <% if (roles.some(role => ['admin'].includes(role))) {%>
                <li class="nav-item">
                    <a class="nav-link approval-rounds-link" href="/workspace/<%= workspaceId %>/rounds">Approval Rounds</a>
                </li>
            <% } %>
            <% if (roles.some(role => ['admin'].includes(role))) {%>
                <li class="nav-item">
                    <a class="nav-link users-link" href="/workspace/<%= workspaceId %>/users">Users</a>
                </li>
            <% } %>
        </ul>
        <p class="first-name"><%= firstName %></p>
        <div class="account-info">
            <p class="full-name"><%= firstName + ' ' + lastName %></p>
            <p><%= email %></p>
            <a href="/auth/logout" class="btn btn-danger">Log Out</a>
        </div>
        </div>
    </div>
    </nav>
<% } %>